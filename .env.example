FRAMEWORK_ENV=local
EXECUTION_MODE=hybrid
LAB_TOPOLOGY_PATH=labs/current_lab.yaml
DEVICE_HOST=lab-edge-01
DEVICE_PLATFORM=cisco_iosxe
DEVICE_TRANSPORT=system
DEVICE_AUTH_USERNAME=lab-user
DEVICE_AUTH_PASSWORD=change-me
DEVICE_RUNNING_CONFIG=hostname lab-edge-01\nbanner login Authorized Access Only\nservice password-encryption\nip ssh version 2\nline vty 0 4\n transport input ssh
OFFLINE_SNAPSHOT_NAME=zero_trust_lab
OFFLINE_SNAPSHOT_PATH=labs/snapshots/zero_trust_lab
BATFISH_HOST=localhost
BATFISH_NETWORK=zero_trust_lab
SEGMENTATION_SOURCE=user_subnet
SEGMENTATION_DESTINATION=restricted_subnet
SEGMENTATION_EXPECTED_ACTION=deny
SEGMENTATION_SECONDARY_SOURCE=admin_subnet
SEGMENTATION_SECONDARY_DESTINATION=restricted_subnet
SEGMENTATION_SECONDARY_EXPECTED_ACTION=allow
